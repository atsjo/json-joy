{
  "name": "@jsonjoy.com/rpc-error",
  "publishConfig": {
    "access": "public"
  },
  "version": "18.7.0",
  "description": "RPC error class and error codes for JSON RPC APIs",
  "author": {
    "name": "streamich",
    "url": "https://github.com/streamich"
  },
  "homepage": "https://github.com/streamich/json-joy/tree/master/packages/rpc-error",
  "repository": {
    "type": "git",
    "url": "https://github.com/streamich/json-joy.git",
    "directory": "packages/rpc-error"
  },
  "license": "Apache-2.0",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/streamich"
  },
  "keywords": [
    "rpc",
    "error",
    "rpc-error",
    "json-rpc",
    "error-codes",
    "json",
    "joy"
  ],
  "peerDependencies": {
    "tslib": "*"
  },
  "engines": {
    "node": ">=10.0"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "typings": "lib/index.d.ts",
  "files": [
    "LICENSE",
    "lib/"
  ],
  "scripts": {
    "clean": "npx rimraf lib typedocs coverage gh-pages yarn-error.log",
    "build": "tsc -b tsconfig.build.json",
    "typedoc": "typedoc",
    "typecheck": "tsc -b --noEmit",
    "test": "jest --maxWorkers 7"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      ".*/node_modules/.*"
    ],
    "testRegex": ".*/(__tests__|__jest__|demo)/.*(?<!\\.vi)\\.(test|spec)\\.tsx?$",
    "rootDir": ".",
    "testPathIgnorePatterns": [
      "node_modules",
      "\\.vi\\.(test|spec)\\.tsx?$"
    ]
  }
}
