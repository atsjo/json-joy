{
  "name": "@jsonjoy.com/json-crdt-server",
  "publishConfig": {
    "access": "public"
  },
  "version": "18.9.0",
  "description": "JSON CRDT HTTP/Websocket server with persistent storage",
  "author": {
    "name": "streamich",
    "url": "https://github.com/streamich"
  },
  "homepage": "https://github.com/streamich/json-joy/tree/master/packages/json-crdt-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/streamich/json-joy.git",
    "directory": "packages/json-crdt-server"
  },
  "license": "AGPL-3.0-only",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/streamich"
  },
  "bin": "./bin/json-crdt-server.js",
  "files": [
    "LICENSE",
    "lib/",
    "bin/"
  ],
  "keywords": [
    "json-crdt-server",
    "json-crdt",
    "crdt",
    "server",
    "json",
    "crdt",
    "json-crdt",
    "json-crdt-server",
    "json-crdt-repo",
    "syncing",
    "local",
    "local-first",
    "local-first-client",
    "reactive",
    "rpc",
    "reactive-rpc",
    "json-joy"
  ],
  "peerDependencies": {
    "rxjs": "7",
    "tslib": "*"
  },
  "dependencies": {
    "@jsonjoy.com/buffers": "workspace:*",
    "@jsonjoy.com/json-pack": "workspace:*",
    "@jsonjoy.com/json-pointer": "workspace:*",
    "@jsonjoy.com/json-type": "workspace:*",
    "@jsonjoy.com/rpc-error": "workspace:*",
    "@jsonjoy.com/rpc-server": "workspace:*",
    "@jsonjoy.com/util": "workspace:*",
    "abstract-level": "^2.0.1",
    "browser-level": "^1.0.1",
    "classic-level": "^2.0.0",
    "json-joy": "workspace:*",
    "memory-level": "^2.0.0",
    "rxjs": "^7.8.2",
    "sonic-forest": "^1.2.0",
    "thingies": "^2.5.0",
    "tslib": "^2.8.1"
  },
  "engines": {
    "node": ">=18.0"
  },
  "private": true,
  "scripts": {
    "start": "npx ts-node --transpile-only src/main.ts",
    "clean": "npx rimraf lib",
    "build": "tsc -b tsconfig.build.json",
    "typedoc": "typedoc",
    "typecheck": "tsc -b --noEmit",
    "test": "jest --maxWorkers 7",
    "test:e2e": "node -r ts-node/register/transpile-only src/__tests__/e2e/run.ts",
    "test:e2e:jest": "TEST_E2E=1 jest --maxWorkers 1 --no-cache src/__tests__/e2e/json-crdt-server/"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/tsconfig.test.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!@jsonjoy\\.com/)"
    ],
    "testRegex": ".*/(__tests__|__jest__|demo)/.*(?<!\\.vi)\\.(test|spec)\\.tsx?$",
    "rootDir": ".",
    "testPathIgnorePatterns": [
      "node_modules",
      "\\.vi\\.(test|spec)\\.tsx?$",
      "src/__tests__/e2e/"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "webpack": "^5.99.5",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1",
    "wrangler": "^4.81.1"
  }
}
