{
  "name": "@jsonjoy.com/json-crdt-playground",
  "publishConfig": {
    "access": "public"
  },
  "version": "18.9.0",
  "description": "Playground site for JSON CRDT",
  "author": {
    "name": "streamich",
    "url": "https://github.com/streamich"
  },
  "homepage": "https://github.com/streamich/json-joy/tree/master/packages/json-crdt-playground",
  "repository": {
    "type": "git",
    "url": "https://github.com/streamich/json-joy.git",
    "directory": "packages/json-crdt-playground"
  },
  "license": "AGPL-3.0-only",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/streamich"
  },
  "keywords": [
    "json-crdt-playground",
    "json-crdt",
    "playground",
    "json",
    "crdt",
    "site",
    "json-joy"
  ],
  "peerDependencies": {
    "rxjs": "7",
    "tslib": "*"
  },
  "dependencies": {
    "json-joy": "workspace:*",
    "@jsonjoy.com/ui": "workspace:*",
    "@jsonjoy.com/collaborative-ui": "workspace:*"
  },
  "engines": {
    "node": ">=10.0"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "typings": "lib/index.d.ts",
  "files": [
    "LICENSE",
    "lib/"
  ],
  "scripts": {
    "clean": "npx rimraf lib typedocs coverage gh-pages yarn-error.log",
    "build": "tsc -b tsconfig.build.json",
    "typedoc": "typedoc",
    "typecheck": "tsc -b --noEmit",
    "test": "jest --maxWorkers 7"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      ".*/node_modules/.*"
    ],
    "testRegex": ".*/(__tests__|__jest__|demo)/.*(?<!\\.vi)\\.(test|spec)\\.tsx?$",
    "rootDir": ".",
    "testPathIgnorePatterns": [
      "node_modules",
      "\\.vi\\.(test|spec)\\.tsx?$"
    ]
  }
}
